#!/usr/bin/env bash

###############################################################################
# Screen Recorder
#
# Description: Record screen or window (region on wayland) without audio
# Dependencies:
#   Xorg: ffmpeg, xorg-xwininfo
#   Wayland: wf-recorder, slurp
###############################################################################

# shellcheck disable=SC2155

MODE=
IN_BACKGROUND=
PID_FILE="/tmp/recordingpid"
OUT_FILE="$HOME/video-$(date '+%y%m%d-%H%M-%S').mkv"

on_ctrl_c() {
    if [[ -f "$OUT_FILE" ]]; then
        echo ""
        echo "Recording saved to $OUT_FILE"
    fi
    exit 0
}

trap on_ctrl_c INT

# Make sure dependencies are installed
ensure_installed() {
    if ! command -v "$1" > /dev/null; then
        echo "Error: $1 not found"
        exit 1
    fi
}

show_help() {
    cat << EOF
Usage:
  record [option] mode

OPTIONS:
  -b|--background  run in background

MODES:
  screen           record entire screen
  window           record selected window
  stop             stop the recording running in background
EOF
}

#######################################
# Kill existing recording
#######################################
kill_recording() {
    if [[ -n "$IN_BACKGROUND" ]]; then
        return
    fi

    if [[ -f "$PID_FILE" ]]; then
        kill -15 "$(cat $PID_FILE)"
        rm -f "$PID_FILE"
        echo "Recording saved to $OUT_FILE."
    fi
}

#######################################
# Record screen without audio
#######################################
screen() {
    if [[ -n "$WAYLAND_DISPLAY" ]]; then
        ensure_installed wf-recorder

        if [[ -n "$IN_BACKGROUND" ]]; then
            wf-recorder --file="$OUT_FILE" &> /dev/null &
            echo $! > "$PID_FILE"
            echo "Recording started"
        else
            wf-recorder --file="$OUT_FILE"
        fi
    else
        ensure_installed ffmpeg

        local cmd=(
            ffmpeg
            -nostdin        # disable interactive stdin reads
            -hide_banner    # suppress the startup banner
            -loglevel error # show only error messages
            -f x11grab      # use X11 screen capture input
            -show_region 1  # draw the capture region on screen
            -framerate 30   # capture at 30 frames per second
            -i "$DISPLAY"   # read from the current X display
            -c:v libx264    # encode video with H.264
            -qp 0           # use near-lossless quality
            -r 30           # write output at 30 frames per second
            "$OUT_FILE"     # save to the chosen output file
        )
        if [[ -n "$IN_BACKGROUND" ]]; then
            "${cmd[@]}" &> /dev/null &
            echo $! > "$PID_FILE"
            echo "Recording started"
        else
            "${cmd[@]}"
        fi
    fi
}

#######################################
# Record selected window without audio
#######################################
window() {
    if [[ -n "$WAYLAND_DISPLAY" ]]; then
        ensure_installed wf-recorder
        ensure_installed slurp

        local geometry
        if command -v jq > /dev/null && [[ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]]; then
            # selected window (requires installed jq and running hyprland)
            geometry="$(
                hyprctl clients -j |
                    jq -r '.[] | "\(.at[0]),\(.at[1]) \(.size[0])x\(.size[1])"' |
                    slurp
            )"
        else
            # selected region
            geometry="$(slurp)"
        fi

        if [[ -n ${IN_BACKGROUND:-} ]]; then
            wf-recorder -g "$geometry" --file="$OUT_FILE" &> /dev/null &
            echo $! > "$PID_FILE"
            echo "Recording started"
        else
            wf-recorder -g "$geometry" --file="$OUT_FILE"
        fi
    else
        ensure_installed ffmpeg
        ensure_installed xwininfo

        local win_id="$(xwininfo | awk '/^xwininfo: Window id:/ {print $4}')"
        local cmd=(
            ffmpeg
            -nostdin             # disable interactive stdin reads
            -hide_banner         # suppress the startup banner
            -loglevel error      # show only error messages
            -f x11grab           # use X11 screen capture input
            -show_region 1       # draw the capture region on screen
            -window_id "$win_id" # capture only the specified X11 window
            -framerate 30        # capture at 30 frames per second
            -i "$DISPLAY"        # read from the current X display
            -c:v libx264         # encode video with H.264
            -qp 0                # use near-lossless quality
            -r 30                # write output at 30 frames per second
            "$OUT_FILE"          # save to the chosen output file
        )
        if [[ -n "$IN_BACKGROUND" ]]; then
            "${cmd[@]}" &> /dev/null &
            echo $! > "$PID_FILE"
            echo "Recording started"
        else
            "${cmd[@]}"
        fi
    fi
}

main() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -b | --background) IN_BACKGROUND='true' ;;
            screen | window | stop)
                [[ -n "$MODE" ]] && show_help && exit 0
                MODE=$1
                ;;
            *) show_help && exit 0 ;;
        esac
        shift
    done

    case "$MODE" in
        screen) screen ;;
        window) window ;;
        stop) kill_recording ;;
        *) show_help && exit 0 ;;
    esac
}

main "$@"
