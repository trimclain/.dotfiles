#!/usr/bin/env bash

###############################################################################
# Brightness Control
#
# Description: Update brightness and get notifications about it
# Dependencies: dunstify or notify-send, brightnessctl or xrandr (only for Xorg)
###############################################################################

PRIMARY_OUTPUT=
CURRENT_BRIGHTNESS=
NEW_BRIGHTNESS=
MODE="unknown"

ensure_installed() {
    if ! command -v "$1" > /dev/null; then
        echo "Error: $1 not found"
        exit 1
    fi
}

notify() {
    if command -v dunstify > /dev/null; then
        dunstify -a "brightness-control" -r 5555 -u low -h int:value:"$1" -t 1500 "$2 Brightness: ${1}%"
    else
        notify-send "$2 ${1}%" -t 350
    fi
}

send_notification() {
    if [ "$2" = "increase" ] || [ "$2" = "full" ] || [ "$2" = "half" ]; then
        notify "$1" "🔆 "
    elif [ "$2" = "decrease" ] || [ "$2" = "zero" ]; then
        notify "$1" "🔅 "
    else
        notify-send 'Brightness Control' 'Error: something went wrong' -t 3000 -u critical
    fi
}

xrandr_get_brightness() {
    PRIMARY_OUTPUT=$(xrandr -q | awk '/ connected primary /{print $1}')
    # NOTE: the "; exit" leads to 'zsh: broken pipe' in my zsh, use subshell (run in ()) to avoid
    CURRENT_BRIGHTNESS=$(xrandr --verbose | awk -v mon="$PRIMARY_OUTPUT" '
        $1==mon { f=1; next }
        f && /^[[:space:]]*Brightness:/ { print $2; exit }
        f && $1 ~ /connected/ { exit }
    ')
}

update_actual_brightness() {
    local output
    if command -v brightnessctl > /dev/null; then
        output="$(brightnessctl g -P)%"
    elif [[ -z $WAYLAND_DISPLAY ]]; then
        xrandr_get_brightness
        output="$(awk "BEGIN {print $CURRENT_BRIGHTNESS*100}")%"
    else
        output="N/A"
    fi

    echo "$output" > /tmp/current_brightness
}

get_brightness() {
    if [[ ! -f /tmp/current_brightness ]]; then
        update_actual_brightness
    fi
    cat /tmp/current_brightness
}

display_brightness() {
    echo "󰃝 $(get_brightness)"
}

main() {
    ensure_installed notify-send

    # Run this on startup to handles the case when the brightness was changed
    # in another session using a different method
    if [ "$1" = "--update-actual-brightness" ]; then
        update_actual_brightness
        exit 0
    fi

    # To be used by the statusbar
    if [ "$1" = "--get-brightness" ]; then
        display_brightness
        exit 0
    fi

    local output
    if command -v brightnessctl > /dev/null; then

        if [ "$1" = "--increase" ]; then
            MODE="increase"
            brightnessctl s +10% -q
        elif [ "$1" = "--decrease" ]; then
            MODE="decrease"
            brightnessctl s 10%- -q
        elif [ "$1" = "--full" ]; then
            MODE="full"
            brightnessctl s 100% -q
        elif [ "$1" = "--zero" ]; then
            MODE="zero"
            brightnessctl s 0% -q
        elif [ "$1" = "--half" ]; then
            MODE="half"
            brightnessctl s 50% -q
        fi

        output=$(brightnessctl g -P)

    elif [[ -z $WAYLAND_DISPLAY ]]; then
        ####### use xrandr if on xorg and no brightnessctl found #######
        ensure_installed xrandr
        ensure_installed notify-send

        xrandr_get_brightness

        NEW_BRIGHTNESS="$CURRENT_BRIGHTNESS"
        if [ "$1" = "--increase" ]; then
            MODE="increase"
            NEW_BRIGHTNESS=$(awk "BEGIN {print $CURRENT_BRIGHTNESS+0.1}")
            # don't got out of range
            if [[ $NEW_BRIGHTNESS == 1.1 ]]; then
                # still show current even if out of range
                output=$(awk "BEGIN {print $CURRENT_BRIGHTNESS*100}")
                notify "$output" "🔆 "
                exit 0
            fi

        elif [ "$1" = "--decrease" ]; then
            MODE="decrease"
            NEW_BRIGHTNESS=$(awk "BEGIN {print $CURRENT_BRIGHTNESS-0.1}")

            # don't got out of range, but allow 0
            if [[ $NEW_BRIGHTNESS == -0.1 ]]; then
                # still show current even if out of range
                output=$(awk "BEGIN {print $CURRENT_BRIGHTNESS*100}")
                notify "$output" "🔅 "
                exit 0
            fi
        elif [ "$1" = "--full" ]; then
            MODE="full"
            NEW_BRIGHTNESS=1
        elif [ "$1" = "--zero" ]; then
            MODE="zero"
            NEW_BRIGHTNESS=0
        elif [ "$1" = "--half" ]; then
            MODE="half"
            NEW_BRIGHTNESS=0.5
        fi

        # Set Brightness
        xrandr --output "$PRIMARY_OUTPUT" --brightness "$NEW_BRIGHTNESS"

        output=$(awk "BEGIN {print $NEW_BRIGHTNESS*100}")
    fi

    # Write new brightness to a file so it can be read less resource intensive
    echo "$output%" > /tmp/current_brightness
    send_notification "$output" "$MODE"
}

main "$@"
