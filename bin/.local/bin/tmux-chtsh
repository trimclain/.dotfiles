#!/usr/bin/env bash

###############################################################################
# Use https://cht.sh/ to get help
# Dependencies: curl, fzf, less
###############################################################################

LANGUAGES=("bash" "python" "julia" "lua" "html" "css" "javascript" "typescript")
COMMANDS=("xargs" "find" "grep" "sed" "awk" "git")

run() {
    if [ -n "$TMUX" ]; then
        tmux split-window -h bash -c "$1"
    else
        bash -c "$1"
    fi
}

selected=$(
    {
        printf '%s\n' "${LANGUAGES[@]}"
        printf '%s\n' "${COMMANDS[@]}"
    } | fzf
)

if [[ -z $selected ]]; then
    exit 0
fi

read -rep "Enter Query: " query

for item in "${COMMANDS[@]}"; do
    if [[ "$selected" == "$item" ]]; then
        is_command='true'
        break
    fi
done

if [[ "$is_command" == "true" ]]; then
    if [[ -n $query ]]; then
        run "curl -fsSL cht.sh/$selected~$query | less -R"
    else
        run "curl -fsSL cht.sh/$selected | less -R"
    fi
else
    if [[ -n $query ]]; then
        query=$(echo "$query" | tr ' ' '+')
        run "curl -fsSL cht.sh/$selected/$query | less -R"
    else
        run "curl cht.sh/$selected | less -R"
    fi
fi
