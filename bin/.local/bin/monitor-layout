#!/usr/bin/env bash

MODE="$1"
DRY_RUN='false'
if [[ "$2" == "-d" ]]; then
    DRY_RUN='true'
fi

# ANSI Colors
RESET="\033[0m"
YELLOW="\033[33m"
MAGENTA="\033[35m"
CYAN="\033[36m"

ensure_installed() {
    if ! command -v "$1" > /dev/null; then
        echo "Error: $1 not found"
        exit 1
    fi
}

run() {
    if [[ "$DRY_RUN" == "true" ]]; then
        printf '%b' "${YELLOW}Would run:${RESET}"
        for arg in "$@"; do
            printf ' "%s"' "$arg"
        done
        printf '\n'
    else
        "$@" > /dev/null
    fi
}

# TODO: this is not always the case
#INTERNAL_WIDTH="1366"
#INTERNAL_HEIGHT="768"
#INTERNAL_RESOLUTION="${INTERNAL_WIDTH}x${INTERNAL_HEIGHT}"
EXTERNAL_WIDTH="1920"
EXTERNAL_HEIGHT="1080"
EXTERNAL_RESOLUTION="${EXTERNAL_WIDTH}x${EXTERNAL_HEIGHT}"

if [[ -n $WAYLAND_DISPLAY ]]; then
    ###########################################################################
    # WAYLAND
    ###########################################################################
    if [[ -n "$HYPRLAND_INSTANCE_SIGNATURE" ]]; then

        connectedOutputs=$(hyprctl monitors all | awk '$1 == "Monitor"{print $2}')

        hyprland_config_provider=$(hyprctl status | awk '$1 == "configProvider:"{print $2}')

        setup_first() {
            if [[ "$hyprland_config_provider" == "lua" ]]; then
                run hyprctl eval "hl.monitor({ output = '$1', mode = 'preferred', position = 'auto', scale = 'auto', disabled = false })"
                run hyprctl eval "hl.monitor({ output = '$2', disabled = true })"
            else
                run hyprctl keyword monitor "$1,preferred,auto,auto"
                run hyprctl keyword monitor "$2,disable"
            fi
        }
        setup_second() {
            if [[ "$hyprland_config_provider" == "lua" ]]; then
                run hyprctl eval "hl.monitor({ output = '$1', disabled = true })"
                run hyprctl eval "hl.monitor({ output = '$2', mode = 'preferred', position = 'auto', scale = 'auto', disabled = false })"
                if [[ "$3" == "--startup" ]]; then
                    run hyprctl dispatch "hl.dsp.focus({ workspace = 1 })"
                fi
            else
                run hyprctl keyword monitor "$1,disable"
                run hyprctl keyword monitor "$2,preferred,auto,auto"
                # run hyprctl keyword monitor "$2,$EXTERNAL_RESOLUTION,auto,auto"
                if [[ "$3" == "--startup" ]]; then
                    # we're always on workspace 2 on startup for some reason
                    run hyprctl dispatch workspace 1
                fi
            fi
        }
        setup_extend() {
            if [[ "$hyprland_config_provider" == "lua" ]]; then
                run hyprctl eval "hl.monitor({ output = '$1', mode = 'preferred', position = '0x0', scale = 'auto', disabled = false })"
                run hyprctl eval "hl.monitor({ output = '$2', mode = 'preferred', position = 'auto-right', scale = 'auto', disabled = false })"

                run hyprctl eval "hl.workspace_rule({ workspace = '1', monitor = '$2', default = true })"
                run hyprctl eval "hl.workspace_rule({ workspace = '2', monitor = '$2', default = true })"
                run hyprctl eval "hl.workspace_rule({ workspace = '3', monitor = '$2', default = true })"
                run hyprctl eval "hl.workspace_rule({ workspace = '4', monitor = '$2', default = true })"
                run hyprctl eval "hl.workspace_rule({ workspace = '5', monitor = '$2', default = true })"
                run hyprctl eval "hl.workspace_rule({ workspace = '6', monitor = '$2', default = true })"

                run hyprctl eval "hl.workspace_rule({ workspace = '7', monitor = '$1', default = true })"
                run hyprctl eval "hl.workspace_rule({ workspace = '8', monitor = '$1', default = true })"
                run hyprctl eval "hl.workspace_rule({ workspace = '9', monitor = '$1', default = true })"

                # TODO: still need this?
                # run hyprctl dispatch "hl.dsp.focus({ workspace = 7 })"
                # run hyprctl dispatch "hl.dsp.focus({ workspace = 1 })"
            else
                # first on the left of second
                # TODO: should I force my laptop monitor to stay at scale 1 instead of auto being 1.5?
                run hyprctl keyword monitor "$1,preferred,0x0,auto"
                run hyprctl keyword monitor "$2,preferred,auto-right,auto"

                run hyprctl keyword workspace "1, monitor:$2, default:true"
                run hyprctl keyword workspace "2, monitor:$2, default:true"
                run hyprctl keyword workspace "3, monitor:$2, default:true"
                run hyprctl keyword workspace "4, monitor:$2, default:true"
                run hyprctl keyword workspace "5, monitor:$2, default:true"
                run hyprctl keyword workspace "6, monitor:$2, default:true"
                run hyprctl keyword workspace "7, monitor:$1, default:true"
                run hyprctl keyword workspace "8, monitor:$1, default:true"
                run hyprctl keyword workspace "9, monitor:$1, default:true"

                # FIX: workspace 1 is for some reason on $1 but can be seen on both bars
                # NOTE: this gets fixed after I empty workspace 1, go to workspace 7 and come back
                run hyprctl dispatch workspace 7
                run hyprctl dispatch workspace 1

            fi
            run waypaper --backend swaybg --restore
        }
        setup_duplicate() {
            run hyprctl keyword monitor "$1, preferred, auto, 1, mirror, $2"
        }
    else
        current_desktop="${DESKTOP_SESSION:-${XDG_CURRENT_DESKTOP:-current desktop}}"
        echo "Error: $current_desktop is not supported"
        exit 1
    fi
else
    ###########################################################################
    # XORG
    ###########################################################################
    ensure_installed xrandr

    # Get info from xrandr
    connectedOutputs=$(xrandr | awk '$2 == "connected"{print $1}')
    # Get the number of enabled monitors:
    # number=$(xrandr --listmonitors | grep Monitors | awk '{print $NF}')

    # TODO: add --mode, --rate, --scale
    # xrandr --output DVI-D-0 --mode 2560x1440 --rate 59.95 --scale 1.5

    setup_first() {
        if [[ "$DRY_RUN" == "true" ]]; then
            echo "Running 'xrandr --output $1 --auto --output $2 --off'"
        else
            xrandr --output "$1" --auto --output "$2" --off
        fi
    }
    setup_second() {
        if [[ "$DRY_RUN" == "true" ]]; then
            echo "Running 'xrandr --output $2 --mode $EXTERNAL_RESOLUTION --primary --output $1 --off'"
        else
            xrandr --output "$2" --mode "$EXTERNAL_RESOLUTION" --primary --output "$1" --off
        fi
    }
    setup_extend() {
        if [[ "$DRY_RUN" == "true" ]]; then
            echo "Running 'xrandr --output $2 --mode $EXTERNAL_RESOLUTION --right-of $1 --output $1 --auto'"
        else
            xrandr --output "$2" --mode "$EXTERNAL_RESOLUTION" --right-of "$1" --output "$1" --auto
        fi
    }
    setup_duplicate() {
        if [[ "$DRY_RUN" == "true" ]]; then
            echo "Running 'xrandr --output $2 --same-as $1 --auto'"
        else
            xrandr --output "$2" --same-as "$1" --auto
        fi
    }
fi

monitors=()
for display in $connectedOutputs; do
    monitors+=("$display")
done

# External monitor is not always the first one
if [[ ${monitors[0]} == *HDMI* ]]; then
    INTERNAL=${monitors[1]}
    EXTERNAL=${monitors[0]}
else
    INTERNAL=${monitors[0]}
    EXTERNAL=${monitors[1]}
fi

if [[ -z $EXTERNAL ]]; then
    exit
fi

if [[ "$DRY_RUN" == "true" ]]; then
    echo -e "${CYAN}Internal:${RESET} ${MAGENTA}${INTERNAL}${RESET}, ${CYAN}External:${RESET} ${MAGENTA}${EXTERNAL}${RESET}"
fi

if [ "$MODE" = "--first" ]; then
    # Enable first monitor, turn off second one
    setup_first "$INTERNAL" "$EXTERNAL"
elif [ "$MODE" = "--second" ]; then
    # Enable second monitor and make it primary, disable first monitor
    setup_second "$INTERNAL" "$EXTERNAL"
    # TODO: XORG: when first and second monitor have different resolutions,
    # don't use auto, use their resolution instead; problem found in awesomewm
elif [ "$MODE" = "--extend" ]; then
    # Enable dual monitor setup, primary is the monitor, which was primary before
    setup_extend "$INTERNAL" "$EXTERNAL"
    # TODO: XORG: when duplicating monitors with different resolutions,
    # using auto also doesn't work.
elif [ "$MODE" = "--duplicate" ]; then
    # Enable duplicate monitor setup
    setup_duplicate "$INTERNAL" "$EXTERNAL"
elif [ "$MODE" = "--startup" ]; then
    # If there's a connected hmdi output, make --second
    setup_second "$INTERNAL" "$EXTERNAL" "--startup"
fi
