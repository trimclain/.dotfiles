[{
    "layer": "top",
    "output": "${MAIN_MONITOR}",
    "height": 36, // default: 30 (remove for auto height)
    // "width": 1280,
    "spacing": 5, // Gaps between modules in px (default: 4)
    "include": [
        "~/.config/waybar/default-modules.jsonc"
    ],
    "modules-left": ["clock", "hyprland/submap"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": [
        "tray",
        "pulseaudio",
        "backlight",
        "hyprland/language",
        "memory",
        "network",
        "temperature",
        "battery",
        "custom/power"
    ],
    // Docs: https://github.com/Alexays/Waybar/wiki/Module:-Hyprland#workspaces
    "hyprland/workspaces": {
        "format": "{name}",
        "format-icons": {
            "urgent": "",
            // "urgent": "ÔÅ™",
            // "active": "ÔÜí",
            // "active": "ÔÑë"
            "active": "",
            // "default": "ÔÑë"
            // "default": "Ôí™"
            "default": ""
        },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": [],
            "5": [],
            "6": []
        },
        // "persistent-only": true,
        "sort-by-number": true,
        "disable-scroll": true,
        "on-click": "activate"
    },
    // Docs: https://github.com/Alexays/Waybar/wiki/Module:-Hyprland#submap
    "hyprland/submap": {
        "format": "Óöê {}",
        "tooltip": false
    },
    // Docs: https://github.com/Alexays/Waybar/wiki/Module:-Tray
    "tray": {
        // "icon-size": 21,
        "spacing": 7
    },
    // Docs: https://github.com/Alexays/Waybar/wiki/Module:-PulseAudio
    "pulseaudio": {
        "scroll-step": 5, // default: 1%; can be a float
        //"format": "Û∞ïæ {volume}%",
        //"format-muted": "Û∞ñÅ {volume}%",
        "on-click": "~/.local/bin/volume-control --toggle-mute",
        "on-click-right": "pavucontrol",
        "format": "{icon} {volume}%{format_source}",
        "format-bluetooth": "{icon}Ôäì {volume}%",
        "format-bluetooth-muted": "Û∞ñÅ {icon}Ôäì",
        "format-muted": "Û∞ñÅ",
        // "format-source": "ÔÑ∞ {volume}%",
        // "format-source": "ÔÑ∞",
        "format-source": "",
        // "format-source-muted": " (ÔÑ± )",
        // "format-source-muted": " (ÓøÜ )",
        "format-source-muted": " (Û∞ç≠)",
        "format-icons": {
            "headphone": "ÔÄ•",
            "hands-free": "Û∞ãê",
            "headset": "Û∞ãé",
            "phone": "ÔÇï",
            "portable": "ÔÇï",
            "car": "ÔÜπ",
            "default": ["ÔÄ¶", "ÔÄß", "Û∞ïæ", "ÔÄ® "]
        }
    },
    // Docs: https://github.com/Alexays/Waybar/wiki/Module:-Backlight
    "backlight": {
        "scroll-step": 10, // default: 1%; can be a float
        "format": "{icon} {percent}%",
        "format-icons": ["Óéç", "Óèì", "Óèë", "Óèè", "Óèé", "Óèç", "Óèä", "Óèà", "Óéõ"]
    },
    // Docs: https://github.com/Alexays/Waybar/wiki/Module:-Hyprland#language
    "hyprland/language": {
        "format": "ÔÑú {}",
        "format-en": "en",
        "format-ru": "ru",
        "format-de": "de",
        "on-click": "~/.local/bin/keyboard-layout"
        // Get with `hyprctl devices`
        // "keyboard-name": "at-translated-set-2-keyboard"
    },
    // Docs: https://github.com/Alexays/Waybar/wiki/Module:-Network
    "network": {
        "interval": 1, // default: 60
        // "format-wifi": "Û∞ñ© {essid}",
        // "format-disconnected": "Û∞ñ™",
        "format-wifi": "Û∞§® {essid}", // this looks good
        "format-disconnected": "Û∞§≠", // with Maple Mono NF
        "format-ethernet": "Û∞£∫ {ipaddr}", // Û∞õ≥
        "tooltip-format": "{ifname} via {gwaddr} Û∞äó",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) Ôá´",
        "tooltip-format-ethernet": "Û∞∏á {bandwidthUpBytes} | Û∞Æè {bandwidthDownBytes}",
        "tooltip-format-disconnected": "Disconnected",
        "max-length": 50,
        // format-icons
        "on-click": "nm-connection-editor",
        "on-click-right": "nm-connection-editor"
    },
    // Docs: https://github.com/Alexays/Waybar/wiki/Module:-Memory
    "memory": {
        // "format": "{percentage}% ÔÉâ"
        "format": "Û∞çõ {used:0.2f} GiB ({percentage}%)",
        "tooltip-format": "{used:0.2f} GiB / {total:0.2f} GiB",
        "interval": 1, // default: 30
        "on-click": "kitty -e btop"
    },
    // Docs: https://github.com/Alexays/Waybar/wiki/Module:-Temperature
    "temperature": {
        // "interval":  1, // default: 10
        // "thermal-zone": 2,
        // "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 90,
        "format": "{icon} {temperatureC}¬∞C",
        "format-icons": ["Ôãã", "Ôãä", "Ôãâ", "Ôãà", "Ôãá"],
        "tooltip": false
    },
    // Docs: https://github.com/Alexays/Waybar/wiki/Module:-Battery
    "battery": {
        "interval": 1, // default: 60
        "states": {
            // "good": 95,
            "warning": 30
        },
        "format": "{icon} {capacity}%",
        "format-charging": "Û∞ÇÑ {capacity}%",
        "format-plugged": "Û∞ÇÑ {capacity}%",
        // "format-alt": "{time} {icon}",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        // "format-icons": ["ÔâÑ", "ÔâÉ", "ÔâÇ", "ÔâÅ", "ÔâÄ"]
        "format-icons": ["Û∞Çé", "Û∞Å∫", "Û∞Åª", "Û∞Åº", "Û∞ÅΩ", "Û∞Åæ", "Û∞Åø", "Û∞ÇÄ", "Û∞ÇÅ", "Û∞ÇÇ", "Û∞Åπ"]
    },
    // Docs: https://github.com/Alexays/Waybar/wiki/Module:-Custom
    "custom/power": {
        // "format": "Û∞§Ü", // nf-md-power_standby
        "format": "Û∞ê•", // nf-md-power
        "on-click": "$HOME/.local/bin/powermenu --use-powertheme",
        "on-click-right": "rofi -show drun"
    }
}, {
    "layer": "top",
    "output": "!${MAIN_MONITOR}", // exclude main monitor
    "height": 36, // default: 30 (remove for auto height)
    // "width": 1280,
    "spacing": 5, // Gaps between modules in px (default: 4)
    "include": [
        "~/.config/waybar/default-modules.jsonc"
    ],
    "modules-left": ["clock"],
    "modules-center": ["hyprland/workspaces"],
    "modules-right": [],
    // Docs: https://github.com/Alexays/Waybar/wiki/Module:-Hyprland#workspaces
    "hyprland/workspaces": {
        "format": "{name}",
        "persistent-workspaces": {
            "7": [],
            "8": [],
            "9": []
        },
        // "persistent-only": true,
        "sort-by-number": true,
        "disable-scroll": true,
        "on-click": "activate"
    }
}]
